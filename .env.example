YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# Optional: path to a token.json from google-auth-oauthlib.
# When set, enables playlist management tools (list, get items, add, remove, move).
# Generate with the Python OAuth flow targeting scope: https://www.googleapis.com/auth/youtube
YOUTUBE_OAUTH_TOKEN_PATH=/path/to/token.json

# Optional: override the SQLite cache path used by the persistence layer.
# Defaults to W:\youtube_mcp_db\youtube-data.db on Windows.
# When overridden, the parent directory must already exist.
YOUTUBE_MCP_DB_PATH=W:\youtube_mcp_db\youtube-data.db
