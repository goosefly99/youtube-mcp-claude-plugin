{
  "mcpServers": {
    "youtube-mcp": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/start.mjs"],
      "env": {
        "YOUTUBE_API_KEY": "${YOUTUBE_API_KEY}",
        "YOUTUBE_OAUTH_TOKEN_PATH": "${YOUTUBE_OAUTH_TOKEN_PATH}",
        "YOUTUBE_MCP_DB_PATH": "${YOUTUBE_MCP_DB_PATH}"
      }
    }
  }
}
